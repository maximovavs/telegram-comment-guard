# Один деплой = один токен бота
BOT_TOKEN=PUT_BOT_TOKEN_HERE

# Какой конфиг чатов использовать для этого деплоя
CONFIG_PATH=config/friend_bot.json

# Твои user_id через запятую. Этих пользователей бот не трогает.
OWNER_USER_IDS=123456789

DEFAULT_DELETE_NOTICE_AFTER_SECONDS=20
DEFAULT_WARNING_TEMPLATE=Комментарий удалён, потому что он не был привязан ни к одному посту.\n\n<b>Ваш текст:</b>\n{text}
